# Copy this file to ".env" and fill in the two values from your Supabase project
# (Supabase dashboard → Project Settings → API). The anon key is safe to expose
# in the browser — Row Level Security is what protects your data.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
